{
  "name": "brainrot-cursor-extension",
  "displayName": "Brainrot - Sound & Image on Failure",
  "description": "Plays a sound and shows a random meme whenever your tests, builds, or programs fail in the terminal.",
  "version": "0.1.3",
  "publisher": "Titus7490",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "brainrot.enable",
        "title": "Brainrot: Enable Sound on Failure"
      },
      {
        "command": "brainrot.disable",
        "title": "Brainrot: Disable Sound on Failure"
      },
      {
        "command": "brainrot.testSound",
        "title": "Brainrot: Test the Sound"
      },
      {
        "command": "brainrot.testImage",
        "title": "Brainrot: Test Failure Image"
      },
      {
        "command": "brainrot.openGames",
        "title": "Brainrot: Open Games"
      },
      {
        "command": "brainrot.typingGame",
        "title": "Brainrot: Typing Game"
      },
      {
        "command": "brainrot.cookieClicker",
        "title": "Brainrot: Cookie Clicker"
      },
      {
        "command": "brainrot.snooze",
        "title": "Brainrot: Snooze (temporarily disable)"
      },
      {
        "command": "brainrot.menu",
        "title": "Brainrot: Open Menu"
      }
    ],
    "configuration": {
      "title": "Brainrot",
      "properties": {
        "brainrot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch — enable or disable all failure sounds."
        },
        "brainrot.onTestFailure": {
          "type": "boolean",
          "default": true,
          "description": "Play sound when a test command fails."
        },
        "brainrot.onBuildFailure": {
          "type": "boolean",
          "default": false,
          "description": "Play sound when a build or compile command fails."
        },
        "brainrot.onRuntimeFailure": {
          "type": "boolean",
          "default": false,
          "description": "Play sound when a runtime command (server, script) crashes."
        },
        "brainrot.onAnyFailure": {
          "type": "boolean",
          "default": true,
          "description": "Play sound on ANY non-zero exit code. Overrides category-specific settings. Can be noisy!"
        },
        "brainrot.sound": {
          "type": "string",
          "default": "faaaah",
          "enum": [
            "random",
            "faaaah",
            "fatality",
            "joker",
            "aaaaaaaa",
            "ack",
            "bone-crack",
            "bruh",
            "error",
            "fortnite",
            "fortnite-bass-boosted",
            "get-out",
            "gunshot",
            "metal-pipe-clang",
            "rehehehe",
            "vine"
          ],
          "enumDescriptions": [
            "🎲 Random pick each time",
            "Classic sad trombone",
            "Mortal Kombat fatality",
            "Why so serious?",
            "AAAAAAAA scream",
            "Ack! Surprised reaction",
            "Bone crack sound effect",
            "Bruh moment",
            "Error alert sound",
            "Fortnite default dance",
            "Fortnite bass boosted",
            "Get out! meme",
            "Gunshot sound effect",
            "Metal pipe clang",
            "Rehehehe evil laugh",
            "Vine boom sound effect"
          ],
          "description": "Which built-in sound to play on failure."
        },
        "brainrot.volume": {
          "type": "number",
          "default": 0.7,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Playback volume (0.1 to 1.0)."
        },
        "brainrot.customSoundPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a custom .wav file. Overrides the built-in sound selection when set."
        },
        "brainrot.extraTestCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command names to treat as test runs (e.g. 'my-test-runner')."
        },
        "brainrot.extraBuildCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command names to treat as build/compile runs (e.g. 'my-build-tool')."
        },
        "brainrot.extraRunCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command names to treat as runtime runs (e.g. 'my-server')."
        },
        "brainrot.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification with a random message when a failure is detected."
        },
        "brainrot.showFailureImage": {
          "type": "boolean",
          "default": false,
          "description": "Open a random image from the failure-images folder when an error is detected."
        },
        "brainrot.failureImagesPath": {
          "type": "string",
          "default": "",
          "description": "Path to a folder of failure images relative to the workspace root (png, jpg, gif, webp). Leave empty to use 'failure-images/' in the workspace root."
        },
        "brainrot.failureImageDuration": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "How many seconds the failure image stays open before auto-closing (1–60)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
